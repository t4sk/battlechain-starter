# Your wallet's public address — used by scripts to derive the deployer address.
# No private key needed here. Import your key into Foundry's keystore instead:
#   cast wallet import battlechain --interactive
SENDER_ADDRESS=

# ── Filled in after running: just setup ───────────────────────────────────────
TOKEN_ADDRESS=
VAULT_ADDRESS=

# ── Filled in after running: just create-agreement ────────────────────────────
AGREEMENT_ADDRESS=

# ── The asset recovery address (receives returned funds after an attack) ───────
# Set to your wallet address (same as SENDER_ADDRESS for this tutorial)
RECOVERY_ADDRESS=
